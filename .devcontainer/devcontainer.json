{
  "name": "React Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:16",
  "features": {
    "node": "latest"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "forwardPorts": [3000],
  "postCreateCommand": "npm install"
}
